# poly-paper environment variables — copy to .env for local runs.

# Database. Default local SQLite. On Railway, set this to the Postgres URL from the plugin.
# DATABASE_URL=sqlite+aiosqlite:///./poly_paper.db
# DATABASE_URL=postgresql://user:pass@host:5432/dbname

# HTTP server port. Railway sets $PORT automatically; local default 8080.
PORT=8080

# Mode: "paper" (default, safe) or "live" (not yet implemented).
POLY_MODE=paper

# Total paper bankroll in USD.
POLY_BANKROLL_USD=1000

# Main loop tick interval in seconds.
POLY_TICK_SECONDS=10

# /readyz fails if no tick within this many seconds.
POLY_TICK_TOLERANCE=120

# Volatility recompute interval (how often we re-pull BTC price history).
POLY_VOL_REFRESH_SECONDS=1800

# Which strategy families to enable (comma-separated).
POLY_FAMILIES=btc_up_down_5m,btc_up_down_15m

# Arb scanner config.
POLY_ARB_SCAN_SECONDS=30
POLY_ARB_MIN_LIQ=1000

# Set to any value for JSON-format logs (recommended for Railway).
# JSON_LOGS=1
